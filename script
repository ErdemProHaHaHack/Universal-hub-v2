-- SPEED INPUT BOXES
local function createInput(text, default, callback)
    local container = Instance.new("Frame", scroll)
    container.Size = UDim2.new(0.9, 0, 0, 40)
    container.BackgroundTransparency = 1

    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Text = text
    label.TextColor3 = Color3.new(1, 1, 1)
    label.BackgroundTransparency = 1

    local input = Instance.new("TextBox", container)
    input.Size = UDim2.new(0.4, 0, 0.8, 0)
    input.Position = UDim2.new(0.5, 0, 0.1, 0)
    input.Text = tostring(default)
    input.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    input.TextColor3 = Color3.new(1, 1, 1)
    
    input.FocusLost:Connect(function()
        callback(tonumber(input.Text))
    end)
end

createInput("Fly Speed:", 50, function(v) _G.HubSettings.FlySpeed = v or 50 end)
createInput("Walk Speed:", 16, function(v) _G.HubSettings.WalkSpeed = v or 16 end)
createInput("Jump Power:", 50, function(v) _G.HubSettings.JumpPower = v or 50 end)

-- BUTTON HELPER
_G.CreateBtn = function(text, callback)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.MouseButton1Click:Connect(callback)
end
-- [[ PART 3: FEATURES LOGIC ]] --
if not _G.CreateBtn then print("Please execute Part 1 and 2 first!") return end

local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")

-- 1. Fly
_G.CreateBtn("Fly (Toggle)", function()
    _G.HubSettings.IsFlying = not _G.HubSettings.IsFlying
    local char = player.Character
    if _G.HubSettings.IsFlying then
        local bv = Instance.new("BodyVelocity", char.HumanoidRootPart)
        bv.Name = "FlyBV"
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        local bg = Instance.new("BodyGyro", char.HumanoidRootPart)
        bg.Name = "FlyBG"
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        char.Humanoid.PlatformStand = true
    else
        if char.HumanoidRootPart:FindFirstChild("FlyBV") then char.HumanoidRootPart.FlyBV:Destroy() end
        if char.HumanoidRootPart:FindFirstChild("FlyBG") then char.HumanoidRootPart.FlyBG:Destroy() end
        char.Humanoid.PlatformStand = false
    end
end)

-- 2. Noclip
_G.CreateBtn("Noclip (Toggle)", function()
    _G.HubSettings.Noclip = not _G.HubSettings.Noclip
end)

-- 3. Infinite Jump
_G.CreateBtn("Inf Jump (Toggle)", function()
    _G.HubSettings.InfJump = not _G.HubSettings.InfJump
end)

-- 4. ESP (Simple)
_G.CreateBtn("ESP (Toggle)", function()
    _G.HubSettings.ESP = not _G.HubSettings.ESP
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player and p.Character then
            if _G.HubSettings.ESP then
                Instance.new("Highlight", p.Character).FillColor = Color3.new(1,0,0)
            else
                for _, v in pairs(p.Character:GetChildren()) do if v:IsA("Highlight") then v:Destroy() end end
            end
        end
    end
end)

-- 5. Apply WalkSpeed
_G.CreateBtn("Set WalkSpeed", function()
    player.Character.Humanoid.WalkSpeed = _G.HubSettings.WalkSpeed
end)

-- 6. Apply JumpPower
_G.CreateBtn("Set JumpPower", function()
    player.Character.Humanoid.UseJumpPower = true
    player.Character.Humanoid.JumpPower = _G.HubSettings.JumpPower
end)

-- 7. Low Gravity
_G.CreateBtn("Low Gravity", function()
