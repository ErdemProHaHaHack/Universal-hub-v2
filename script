local keyFile = "UniversalHub_v2_Key.txt"
local CORRECT_KEY = "woahmyuniversalscriptissoopv2"
local keyExists = false

pcall(function()
    if (readfileexists and readfileexists(keyFile)) or (isfile and isfile(keyFile)) then
        keyExists = true
    end
end)

if keyExists then
    pcall(function()
        if readfile(keyFile) == CORRECT_KEY then db.Verified.Value = true end
    end)
end

if not db.Verified.Value then
    local screenGui = Instance.new("ScreenGui", pg)
    local keyFrame = Instance.new("Frame", screenGui)
    keyFrame.Size = UDim2.new(0, 300, 0, 200)
    keyFrame.Position = UDim2.new(0.5, -150, 0.5, -100)
    keyFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", keyFrame).CornerRadius = UDim.new(0, 15)
    Instance.new("UIStroke", keyFrame).Color = Color3.fromRGB(0, 120, 215)

    local title = Instance.new("TextLabel", keyFrame)
    title.Size = UDim2.new(1, 0, 0, 50); title.Text = "UNIVERSAL HUB v2"; title.TextColor3 = Color3.new(1,1,1); title.BackgroundColor3 = Color3.fromRGB(30,30,30); Instance.new("UICorner", title)

    local input = Instance.new("TextBox", keyFrame)
    input.Size = UDim2.new(0.8, 0, 0, 45); input.Position = UDim2.new(0.1, 0, 0.35, 0); input.PlaceholderText = "Enter Key..."; input.BackgroundColor3 = Color3.fromRGB(40,40,40); input.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", input)

    local btn = Instance.new("TextButton", keyFrame)
    btn.Size = UDim2.new(0.8, 0, 0, 45); btn.Position = UDim2.new(0.1, 0, 0.65, 0); btn.Text = "Verify"; btn.BackgroundColor3 = Color3.fromRGB(0, 120, 215); btn.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", btn)

    btn.MouseButton1Click:Connect(function()
        if input.Text == CORRECT_KEY then
            pcall(function() writefile(keyFile, CORRECT_KEY) end)
            btn.Text = "Success!"
            btn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
            task.wait(1)
            btn.Text = "Pls rejoin and execute script again"
            btn.Size = UDim2.new(0.9, 0, 0, 30)
            btn.Position = UDim2.new(0.05, 0, 0.65, 0)
            task.wait(5)
            screenGui:Destroy()
        else
            btn.Text = "Wrong Key!"; task.wait(1); btn.Text = "Verify"
        end
    end)
    return 
end
