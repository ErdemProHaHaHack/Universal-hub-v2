-- AIMBOT (Reset-Proof)
local function getClosestPlayer()
    local closest, dist = nil, math.huge
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local pos = p.Character.HumanoidRootPart.Position
            local magnitude = (pos - camera.CFrame.Position).Magnitude
            if magnitude < dist then
                local rayParams = RaycastParams.new()
                rayParams.FilterDescendantsInstances = {player.Character, p.Character}
                rayParams.FilterType = Enum.RaycastFilterType.Exclude
                if not workspace:Raycast(camera.CFrame.Position, (pos - camera.CFrame.Position).Unit * magnitude, rayParams) then
                    dist = magnitude; closest = p
                end
            end
        end
    end
    return closest
end

-- ANA LOOP (Sürekli Karakter Kontrolü Yapar)
RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChildOfClass("Humanoid") then 
        -- Karakter yoksa veya henüz yüklenmemişse işlem yapma, hata verme.
        return 
    end
    
    local root = char.HumanoidRootPart
    local hum = char:FindFirstChildOfClass("Humanoid")

    -- AIMBOT
    if db.Aimbot.Value then
        local target = getClosestPlayer()
        if target then camera.CFrame = CFrame.new(camera.CFrame.Position, target.Character.HumanoidRootPart.Position) end
    end

    -- HD FLY (Kaskatı Duruş)
    if db.IsFlying.Value then
        local bv = root:FindFirstChild("FlyBV") or Instance.new("BodyVelocity", root)
        bv.Name = "FlyBV"; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        local bg = root:FindFirstChild("FlyBG") or Instance.new("BodyGyro", root)
        bg.Name = "FlyBG"; bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        
        bv.Velocity = camera.CFrame.LookVector * db.FlySpeed.Value
        bg.CFrame = camera.CFrame
        hum.PlatformStand = true
    else
        if root:FindFirstChild("FlyBV") then root.FlyBV:Destroy() end
        if root:FindFirstChild("FlyBG") then root.FlyBG:Destroy() end
        hum.PlatformStand = false
    end

    -- SPEED & JUMP (Anlık Uygulama)
    hum.WalkSpeed = db.SpeedHack.Value and db.WalkSpeed.Value or 16
    hum.JumpPower = db.JumpHack.Value and db.JumpPower.Value or 50
    hum.UseJumpPower = true

    -- NOCLIP
    if db.Noclip.Value then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    end
end)

