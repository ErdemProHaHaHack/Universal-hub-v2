-- Speed Input Function
local function createInput(text, valName)
    local container = Instance.new("Frame", scroll)
    container.Size = UDim2.new(0.9, 0, 0, 40)
    container.BackgroundTransparency = 1
    local label = Instance.new("TextLabel", container)
    label.Size = UDim2.new(0.5, 0, 1, 0)
    label.Text = text
    label.TextColor3 = Color3.new(1, 1, 1)
    label.BackgroundTransparency = 1
    local input = Instance.new("TextBox", container)
    input.Size = UDim2.new(0.4, 0, 0.8, 0)
    input.Position = UDim2.new(0.5, 0, 0.1, 0)
    input.Text = tostring(db[valName].Value)
    input.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    input.TextColor3 = Color3.new(1, 1, 1)
    input.FocusLost:Connect(function() db[valName].Value = tonumber(input.Text) or db[valName].Value end)
end

createInput("Fly Speed:", "FlySpeed")
createInput("Walk Speed:", "WalkSpeed")
createInput("Jump Power:", "JumpPower")

-- Create button helper for Part 3
_G.AddHubBtn = function(text, callback)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.MouseButton1Click:Connect(callback)
end
-- [[ PART 3: ENGINE LOGIC ]] --
local player = game.Players.LocalPlayer
local pg = player:WaitForChild("PlayerGui")
local db = pg:WaitForChild("HubData_v2")
local RunService = game:GetService("RunService")

if not _G.AddHubBtn then print("Execute Part 2 first!") return end

-- 1. Fly Toggle
_G.AddHubBtn("Fly (Toggle)", function()
    db.IsFlying.Value = not db.IsFlying.Value
    local char = player.Character
    if not char then return end
    if db.IsFlying.Value then
        local bv = Instance.new("BodyVelocity", char.HumanoidRootPart)
        bv.Name = "FlyBV"; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        local bg = Instance.new("BodyGyro", char.HumanoidRootPart)
        bg.Name = "FlyBG"; bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        char.Humanoid.PlatformStand = true
    else
        if char.HumanoidRootPart:FindFirstChild("FlyBV") then char.HumanoidRootPart.FlyBV:Destroy() end
        if char.HumanoidRootPart:FindFirstChild("FlyBG") then char.HumanoidRootPart.FlyBG:Destroy() end
        char.Humanoid.PlatformStand = false
    end
end)

-- 2. Noclip Toggle
_G.AddHubBtn("Noclip (Toggle)", function() db.Noclip.Value = not db.Noclip.Value end)

-- 3. Inf Jump Toggle
_G.AddHubBtn("Inf Jump (Toggle)", function() db.InfJump.Value = not db.InfJump.Value end)

-- 4. ESP Toggle
_G.AddHubBtn("ESP (Toggle)", function()
    db.ESP.Value = not db.ESP.Value
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= player and p.Character then
            if db.ESP.Value then Instance.new("Highlight", p.Character).FillColor = Color3.new(1,0,0)
            else for _, v in pairs(p.Character:GetChildren()) do if v:IsA("Highlight") then v:Destroy() end end end
        end
    end
end)

-- 5. WalkSpeed Applier
_G.AddHubBtn("Apply WalkSpeed", function() player.Character.Humanoid.WalkSpeed = db.WalkSpeed.Value end)

-- 6. JumpPower Applier
_G.AddHubBtn("Apply JumpPower", function() 
    player.Character.Humanoid.UseJumpPower = true
    player.Character.Humanoid.JumpPower = db.JumpPower.Value 
end)

-- 7. Low Gravity
_G.AddHubBtn("Low Gravity", function() workspace.Gravity = 50 end)

-- 8. Normal Gravity
_G.AddHubBtn("Normal Gravity", function() workspace.Gravity = 196.2 end)

-- 9. Fullbright
_G.AddHubBtn("Fullbright", function() game.Lighting.Brightness = 2 game.Lighting.ClockTime = 14 end)

-- 10. Wide FOV
_G.AddHubBtn("Wide FOV", function() workspace.CurrentCamera.FieldOfView = 100 end)

-- Loops
RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char then return end
    if db.IsFlying.Value then
        local bv = char.HumanoidRootPart:FindFirstChild("FlyBV")
        local bg = char.HumanoidRootPart:FindFirstChild("FlyBG")
        if bv and bg then
            bv.Velocity = workspace.CurrentCamera.CFrame.LookVector * db.FlySpeed.Value
            bg.CFrame = workspace.CurrentCamera.CFrame
        end
    end
    if db.Noclip.Value then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    end
end)

game:GetService("UserInputService").JumpRequest:Connect(function()
    if db.InfJump.Value then player.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping") end
end)
