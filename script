local function createVal(class, name, val)
    local v = Instance.new(class)
    v.Name = name; v.Value = val; v.Parent = db
end

createVal("BoolValue", "Verified", false)
createVal("BoolValue", "IsFlying", false)
createVal("BoolValue", "Noclip", false)
createVal("BoolValue", "InfJump", false)
