end)

-- 9. Fullbright (Removes darkness)
_G.CreateBtn("Fullbright", function()
    game:GetService("Lighting").Brightness = 2
    game:GetService("Lighting").ClockTime = 14
    game:GetService("Lighting").FogEnd = 100000
end)

-- 10. FOV Zoom Out
_G.CreateBtn("Wide FOV", function()
    game.Workspace.CurrentCamera.FieldOfView = 100
end)

-- BACKGROUND LOOPS
RunService.RenderStepped:Connect(function()
    local char = player.Character
    if not char then return end
    
    if _G.HubSettings.IsFlying then
        local root = char:FindFirstChild("HumanoidRootPart")
        local bv = root:FindFirstChild("FlyBV")
        local bg = root:FindFirstChild("FlyBG")
        if bv and bg then
            local cam = workspace.CurrentCamera
            bv.Velocity = cam.CFrame.LookVector * _G.HubSettings.FlySpeed
            bg.CFrame = cam.CFrame
        end
    end
    
    if _G.HubSettings.Noclip then
        for _, v in pairs(char:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

game:GetService("UserInputService").JumpRequest:Connect(function()
    if _G.HubSettings.InfJump then
        player.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)
